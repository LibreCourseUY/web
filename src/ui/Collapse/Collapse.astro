---
import Text from '@/components/Text/Text';
interface Props {
	question: string;
	open?: boolean;
}

const { question, open = false } = Astro.props;
---

<div class:list={['faq-item group border-t border-white/10', { open }]}>
	<button
		class="faq-trigger w-full flex items-center justify-between gap-4 py-5 text-left cursor-pointer
      font-sans text-[15px] bg-transparent border-none
      transition-colors duration-200 hover:text-emphasis/80"
		aria-expanded={open ? 'true' : 'false'}
	>
		<span><Text.P>{question}</Text.P></span>
		<span
			class="faq-icon shrink-0 font-mono text-lg text-neutral-700/45
        transition-[transform,color] duration-300 ease-in-out
        group-[.open]:rotate-45 group-hover:text-neutral-400"
			aria-hidden="true"
		>
			+
		</span>
	</button>

	<div
		class="faq-body overflow-hidden
      max-h-0 group-[.open]:max-h-48
      transition-[max-height] duration-350 ease-in-out"
	>
		<Text.P className="pb-5 text-emphasis/80 leading-7">
			<slot />
		</Text.P>
	</div>
</div>

<script>
	document.querySelectorAll<HTMLElement>('.faq-item').forEach((item) => {
		const trigger = item.querySelector<HTMLButtonElement>('.faq-trigger');

		trigger?.addEventListener('click', () => {
			const isOpen = item.classList.contains('open');

			// Cierra todos los items abiertos
			document.querySelectorAll('.faq-item.open').forEach((el) => {
				el.classList.remove('open');
				el.querySelector<HTMLButtonElement>('.faq-trigger')?.setAttribute('aria-expanded', 'false');
			});

			// Abre el clickeado si estaba cerrado
			if (!isOpen) {
				item.classList.add('open');
				trigger.setAttribute('aria-expanded', 'true');
			}
		});
	});
</script>
