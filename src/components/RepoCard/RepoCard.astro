---
import type { ProjectsGitHubType } from '@/lib/types';
import {formatDate} from '@/lib/utils';

interface Props extends Omit<ProjectsGitHubType['data'], 'id'> {
	variant?: 'default' | 'fork' | 'archived';
	featured?: boolean;
	previewLines?: boolean;
}

const {
	name,
	description,
	topics = [],
	language,
	stars,
	updatedAt,
	url = '#',
} = Astro.props;

const MAX_TOPICS = 5;

---

<a
	href={url}
	target="_blank"
	rel="noopener noreferrer"
	class:list={[
		'group flex flex-col gap-3 rounded-lg border border-neutral-700 bg-neutral-900/50 p-4 no-underline transition-colors duration-150 hover:border-emphasis/60'
	]}
>
	<div class="flex items-center gap-2">
		<span
			class="text-sm font-bold text-emphasis truncate flex-1"
		>
			{name}
		</span>
	</div>

	{
		description && (
			<p class="line-clamp-2 text-sm leading-relaxed text-neutral-400">{description}</p>
		)
	}

	{
		topics.length > 0 && (
			<div class="flex flex-wrap gap-1">
				{topics.toSpliced(MAX_TOPICS, topics.length-1).map((topic) => (
					<span class="rounded bg-neutral-800 px-1.5 py-0.5 text-[0.7rem] text-emphasis">
						{topic}
					</span>
				))}
			</div>
		)
	}

	<div
		class="mt-auto flex flex-wrap items-center gap-3.5 border-t border-neutral-700 pt-3 text-xs text-neutral-400"
	>
		{language && <span class='underline text-emphasis'>{language}</span>}
		{
			stars !== undefined && stars > 0 && (
				<span class="flex items-center gap-1">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="13"
						height="13"
						viewBox="0 0 24 24"
						fill="yellow"
						stroke="currentColor"
						stroke-width="1.5"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<>
							<path
								stroke="none"
								d="M0 0h24v24H0z"
								fill="none"
							/>
							<path d="M12 17.75l-6.172 3.245l1.179 -6.873l-5 -4.867l6.9 -1l3.086 -6.253l3.086 6.253l6.9 1l-5 4.867l1.179 6.873z" />
						</>
					</svg>
					{stars}
				</span>
			)
		}
		{updatedAt && <span class="ml-auto">UIpdated at: {formatDate(updatedAt)}</span>}
	</div>
</a>
