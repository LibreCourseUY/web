---
// Utils
import { cn } from '@/lib/utils';

export interface Props {
  className?: string;
  pathname?: string;
}

const { className, pathname } = Astro.props;

const route = [
  { name: "Home", href: "/" },
  { name: "Learn", href: "/learn" },
  { name: "Projects", href: "/projects" },
  { name: "Docs", href: "/docs" },
  { name: "Open source", href: "/open-source" },
  { name: "CLA", href: "/cla" },
];
---

<div
  class={cn(
    className,
    "h-16 w-dvw bg-background/95 px-12 lg:px-24 sticky top-0 backdrop-blur-sm z-50",
  )}
>
  <div
    class={cn("h-16 w-full flex flex-row justify-between items-center")}
  >
    <span>
      <b>
        <a href="/">LibreCourseUY</a>
      </b>
    </span>

    <div class="flex flex-row items-center gap-4">
      <ul class="flex flex-row gap-4">
        {route.map((item, _, arr) => (
          <li key={item.name}>
            <a
              class={cn(
                "text-sm font-bold inline-block",
                arr.at(-1)?.name === item.name
                  ? "pr-0 border-r-0"
                  : "pr-3 border-r border-neutral-700",
                pathname === item.href
                  ? "text-emphasis/60 font-normal"
                  : "text-emphasis hover:text-emphasis/80",
              )}
              href={item.href}
            >
              {item.name}
            </a>
          </li>
        ))}
      </ul>
      <button
        disabled
        id="theme-lang"
        class="bg-emphasis w-12 h-6 rounded-full cursor-pointer disabled:cursor-not-allowed"
      >
        En
      </button>
    </div>
  </div>
</div>
