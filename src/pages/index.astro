---
// Libreries
import { Image } from 'astro:assets';
// Components
import Anchor from '@/components/Anchor/Anchor.astro';
import Text from '@/components/Text/Text.astro';
import List from '@/components/List/List.astro';
import ListItem from '@/components/List/ListItem.astro';
import Cards from '@/components/Cards/Cards.astro';
import Collapse from '@/components/Collapse/Collapse.astro';
// Layout
import Layout from '@/layouts/Layout.astro';
// Utils
import { formatLink } from '@/lib/utils';
import type { ProjectType } from '@/lib/types';
// Assets
import cloudImg from '@/assets/ascii-art-cloud.png';
import computerImg from '@/assets/ascii-art-computer.png';

const aboutList = [
	'<strong class="block">Non-profit</strong> FOSS community based in Uruguay.',
	'<strong class="block">Built for developers at every level </strong>from first commit to seasoned contributor.',
	'Open tools, open curriculum, open processes.',
	'<strong class="block">Growing the next generation </strong>of open source contributors in Latin America.',
];

const importantLinks = {
	discordCommunity: 'https://discord.gg/ZrtwyxcQ',
	github: 'https://github.com/LibreCourseUY',
};

const projects: ProjectType[] = [
	{
		title: 'Inkfing',
		description:
			"simple extension that allows Fing (Facultad de Ingeniería, UdelaR) students to give their day to day web apps a refreshed dark-mode. It's designed to help incoming students find study partners and collaborative projects to work on.",
		autor: {
			name: 'emiliano-gandini',
			link: 'https://github.com/emiliano-gandini-outeda',
		},
		image: null,
		stack: ['HTML', 'CSS', 'JS', 'Manifest V3'],
		pj_link: 'https://github.com/LibreCourseUY/Inkfing',
	},
	{
		title: 'UruAPI',
		description:
			"is a wrapper around datosuruguay.com and exposes Uruguay's daily-updated economic indicators in a clean, JSON-friendly format.",
		autor: {
			name: 'emiliano-gandini',
			link: 'https://github.com/emiliano-gandini-outeda',
		},
		image: null,
		stack: ['Python', 'FastAPI', 'Docker'],
		pj_link: 'https://github.com/LibreCourseUY/UruAPI',
	},
	{
		title: 'KanBan generator',
		description:
			'A highly configurable React component that accepts an array of columns and an array of cards with generic metadata, and supports drag-and-drop interactions between columns.',
		autor: {
			name: 'kevin-ramirez',
			link: 'https://github.com/Kevin-Ramirez127',
		},
		image: null,
		stack: ['React', 'Tailwind', 'Vite', 'Typescript'],
		pj_link: 'https://github.com/LibreCourseUY/kanBan-generator',
	},
];
---

<Layout
	title="LibreCourseUY"
	description="Welcome to LibreCourseUY, a platform for free and open educational resources."
>
	<main class="flex min-h-screen flex-col items-start justify-center">
		<section
			id="hero_section"
			class="flex flex-col justify-start items-start w-full min-h-dvh mt-12 md:pt-12"
		>
			<Text
				variant="h1"
				className="max-w-4xl mb-4 col-start-1 col-end-12 row-start-1 row-end-5 z-10"
			>
				Open Source projects made by students, for students.
			</Text>

			<div class="flex flex-wrap flex-row justify-between w-full gap-4">
				<div class="flex flex-col items-start justify-center space-y-4 shrink-0">
					<Anchor
						className="font-bold whitespace-nowrap"
						href="https://github.com/LibreCourseUY"
					>
						GitHub
					</Anchor>
					<Anchor
						className="font-bold whitespace-nowrap"
						href="https://github.com/LibreCourseUY"
						disabled
					>
						Start Contributing
					</Anchor>
				</div>
				<Image
					src={cloudImg}
					alt="Cloud ASCII art"
					class="object-cover md:mr-auto md:ml-auto"
					inferSize={true}
					loading="eager"
					width={980}
					height={300}
				/>
			</div>
		</section>
		<section
			id="about"
			class="mb-12 w-full flex flex-row flex-wrap md:flex-nowrap items-start justify-center gap-x-12"
		>
			<div class="flex flex-col w-full space-y-12">
				<Text variant="h2">What is <br /> LibreCourseUY</Text>
				<div class="space-y-12">
					<h3 class="text-4xl">Our mision</h3>
					<List className="w-fit">
						{
							aboutList.map((item, i) => (
								<ListItem className="first:border-t border-b border-neutral-700 p-6 flex flex-row justify-start items-center gap-6">
									<span class="mr-3 text-sm">{String(i + 1).padStart(2, '0')}</span>
									<span set:html={item} />
								</ListItem>
							))
						}
					</List>
				</div>
			</div>
			<Image
				src={computerImg}
				alt="Cloud ASCII art"
				class="aspect-video object-cover mt-12 self-center"
				inferSize={true}
				loading="lazy"
				width={720}
				height={380}
			/>
		</section>
		<section
			id="projects"
			class="min-h-dvh mt-12 overflow"
		>
			<div class="space-y-12">
				<Text variant="h2">Our Projects</Text>
				<Text variant="p"
					>Projects made by studients that shows their <br />knowledge in multiple areas</Text
				>
				<div class="space-y-6">
					{
						projects.map((project, i) => (
							<Cards
								{...project}
								index={i}
							/>
						))
					}
				</div>
			</div>
		</section>
		<section id="faq">
			<div class="max-w-200 pt-16 pb-24 space-y-12">
				<Text variant="h1"> Got questions? </Text>
				<div class="[&_.faq-item:last-child]:border-b [&_.faq-item:last-child]:border-white/10">
					<Collapse
						question="What is LibreCourseUY?"
						open
					>
						A non-profit initiative based in Uruguay that helps programmers, from aspiring
						developers to seasoned professionals, contribute to Free and Open Source Software.
					</Collapse>

					<Collapse question="Who can join?">
						Anyone, for free. Members are expected to follow our Code of Conduct, and those who wish
						to contribute must sign the CLA.
					</Collapse>

					<Collapse question="What does LibreCourseUY offer?">
						A strong developer community with common goals, a space to learn and grow your career,
						and real projects worth putting on your CV.
					</Collapse>

					<Collapse question="How do I get started?">
						Read the Code of Conduct, then browse our First Issues list or find a repo you want to
						contribute to. If you're new, check out our Introductory Guide. It covers how to
						collaborate, learn, and get involved.
					</Collapse>

					<Collapse question="Why is everything in English?">
						Open source is a global conversation, and English is its common language. Writing
						issues, PRs, and documentation in English makes your contributions accessible to the
						entire FOSS community, not just Spanish speakers. It also prepares you for real-world
						collaboration on any project, anywhere.
					</Collapse>

					<Collapse question="Where can I find LibreCourseUY?">
						<ListItem
							className="first:border-t border-b border-neutral-700 p-6 flex flex-row justify-start items-center gap-6"
						>
							<span class="mr-3 text-sm">{String(1).padStart(2, '0')}</span>
							<span>
								<Text variant="p">
									Contribute on
									<Anchor href={formatLink(importantLinks.github)}>GitHub</Anchor>
								</Text>
							</span>

							<ListItem
								className="first:border-t border-b border-neutral-700 p-6 flex flex-row justify-start items-center gap-6"
							>
								<span class="mr-3 text-sm">{String(1).padStart(2, '0')}</span>
								<Text variant="p"
									>Join on our
									<Anchor href={formatLink(importantLinks.discordCommunity)}>Discord</Anchor>
									server</Text
								>
							</ListItem>
						</ListItem>
					</Collapse>
				</div>
			</div>
		</section>
		<footer class="min-h-64 flex flex-row gap-x-12 justify-end items-end pb-12">
			<span class="text-emphasis/60">Libre<span>Course</span>UY</span>
			<span class="footer-copy">© 2026 — Open Source Education</span>
		</footer>
	</main>
</Layout>
